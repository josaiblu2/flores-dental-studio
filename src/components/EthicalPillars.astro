---
// EthicalPillars.astro
const pillars = [
  {
    title: "Misión",
    description: "Brindar servicios odontológicos integrales de alta calidad, basados en la ética profesional y la honestidad.",
    icon: `<svg class="w-12 h-12 mb-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>`
  },
  {
    title: "Visión",
    description: "Ser el estudio dental de referencia por nuestra integridad clínica y calidez humana.",
    icon: `<svg class="w-12 h-12 mb-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`
  },
  {
    title: "Slogan",
    description: "Excelencia odontológica con calidez humana.",
    icon: `<svg class="w-12 h-12 mb-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>`
  },
  {
    title: "Valores",
    description: "Honestidad inquebrantable, Empatía, Rigor científico y Transparencia.",
    icon: `<svg class="w-12 h-12 mb-4 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path></svg>`
  }
];
---

<section id="pilares" class="py-20 bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-serif text-3xl md:text-4xl text-white">Nuestros Pilares</h2>
      <div class="w-24 h-1 bg-blue-300 mx-auto mt-4 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      {pillars.map(pillar => (
        <div class="flex flex-col items-center text-center group">
          <div class="p-4 bg-navy-light rounded-2xl transform transition-transform duration-300 group-hover:-translate-y-2 group-hover:shadow-2xl shadow-black/30">
            <Fragment set:html={pillar.icon} />
          </div>
          <h3 class="font-serif text-xl mt-6 mb-4">{pillar.title}</h3>
          <p class="font-sans font-light text-gray-300 text-sm leading-relaxed">
            {pillar.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
