---
// ServiceCatalog.astro
const services = [
  {
    title: "Prevención y Diagnóstico",
    description: "Limpiezas ultrasónicas y diagnósticos honestos.",
    image: "/images/Portafolio_Prevencion.png",
  },
  {
    title: "Odontología Restauradora",
    description: "Resinas de alta estética y rehabilitación funcional.",
    image: "/images/Portafolio_Restauradora.png",
  },
  {
    title: "Estética Dental Mínima Invasión",
    description: "Blanqueamientos y carillas respetando la estructura natural.",
    image: "/images/Portafolio_Estetica.png",
  },
  {
    title: "Atención Integral y Urgencias",
    description: "Resolución eficiente del dolor con protocolos de bioseguridad.",
    image: "/images/Portafolio_Urgencias.png",
  }
];
---

<section id="servicios" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-navy-light tracking-widest uppercase text-xs font-semibold">Portafolio</span>
      <h2 class="font-serif text-3xl md:text-4xl text-navy mt-2">Tratamientos de Excelencia</h2>
      <div class="w-16 h-1 bg-navy mx-auto mt-6 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="group relative overflow-hidden rounded-sm shadow-md hover:shadow-xl transition-shadow bg-white flex flex-col md:flex-row h-full">
          <div class="md:w-2/5 md:flex-shrink-0 h-48 md:h-auto overflow-hidden">
            <img 
              src={service.image} 
              alt={service.title} 
              class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="p-8 md:w-3/5 flex flex-col justify-center">
            <h3 class="text-xl font-serif text-navy mb-3">{service.title}</h3>
            <p class="text-gray-600 font-light text-sm mb-6 leading-relaxed flex-grow">
              {service.description}
            </p>
            <a href="#contacto" class="text-navy font-medium text-sm inline-flex items-center hover:text-blue-600 transition-colors">
              Solicitar información
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
