---
// Hero.astro
---
<section class="relative bg-navy-dark overflow-hidden bg-cover bg-center h-[600px] flex items-center" style="background-image: url('/images/StudioDental.png');">
  {/* Dark overlay for text readability */}
  <div class="absolute inset-0 bg-navy/70 mix-blend-multiply"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between w-full">
    
    <div class="max-w-2xl text-white space-y-6">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-normal leading-tight">
        Excelencia odontológica con <span class="text-blue-200">calidez humana</span>.
      </h1>
      <p class="font-sans font-light text-lg md:text-xl text-gray-200 max-w-xl">
        Odontología de alta gama enfocada en la transparencia, el diagnóstico honesto y un trato excepcionalmente cálido.
      </p>
      
      <div class="pt-4 flex space-x-4">
        <a href="#contacto" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-sm text-navy bg-white hover:bg-gray-100 transition-colors shadow-lg">
          Agendar Valoración
        </a>
        <a href="#pilares" class="inline-flex items-center justify-center px-8 py-3 border border-white text-base font-medium rounded-sm text-white hover:bg-white/10 transition-colors">
          Nuestra Filosofía
        </a>
      </div>
    </div>
    
  </div>
</section>
