---
import fs from 'node:fs/promises';
import path from 'node:path';

const dataPath = path.join(process.cwd(), 'src/data/testimonials.json');
let published = [];

try {
  const rawData = await fs.readFile(dataPath, 'utf-8');
  const allTestimonials = JSON.parse(rawData);
  // Filter only approved ones
  published = allTestimonials.filter((t: any) => t.is_published === true);
} catch (error) {
  console.error("Error reading testimonials:", error);
}

// Helper to truncate last name: "Salvador Ibarra" -> "Salvador I."
const truncateName = (fullName: string) => {
  const parts = fullName.trim().split(' ');
  if (parts.length > 1) {
    const firstName = parts[0];
    const lastName = parts[parts.length - 1];
    return `${firstName} ${lastName.charAt(0)}.`;
  }
  return fullName;
};
---

<section id="testimonios" class="py-24 bg-navy-dark text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-blue-300 tracking-widest uppercase text-xs font-semibold">Experiencias Reales</span>
      <h2 class="font-serif text-3xl md:text-4xl mt-2">Lo que dicen nuestros pacientes</h2>
      <div class="w-16 h-1 bg-blue-300 mx-auto mt-6 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      {published.map((t) => (
        <div class="bg-navy p-8 rounded shadow-lg border-t-2 border-blue-400">
          <svg class="h-8 w-8 text-blue-300 mb-4 opacity-50" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-gray-200 font-light italic mb-6 leading-relaxed">"{t.comentario}"</p>
          <div class="flex items-center">
            <div class="h-10 w-10 bg-blue-900 rounded-full flex items-center justify-center text-blue-200 font-serif font-bold">
              {t.nombre_paciente.charAt(0)}
            </div>
            <div class="ml-4">
              <h4 class="font-medium text-white">{truncateName(t.nombre_paciente)}</h4>
              <p class="text-xs text-blue-300 font-light">Paciente Verificado</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Submission Form for new testimonials (Injection Test via QA) */}
    <div class="max-w-2xl mx-auto bg-navy rounded p-8 border border-navy-light text-center">
      <h3 class="font-serif text-2xl mb-2">¿Nos visitaste recientemente?</h3>
      <p class="text-gray-300 font-light text-sm mb-6">Comparte tu experiencia. Tu reseña ayuda a otros pacientes a encontrar atención odontológica ética.</p>
      
      <form action="/api/testimonials" method="POST" class="space-y-4 text-left">
        <div>
          <label for="nombre_paciente" class="block text-xs text-blue-200 mb-1">Nombre Completo</label>
          <input type="text" id="nombre_paciente" name="nombre_paciente" required class="w-full bg-navy-dark border border-navy-light rounded px-3 py-2 text-white focus:outline-none focus:border-blue-400 text-sm" placeholder="Ej. Juan Pérez" />
        </div>
        <div>
          <label for="comentario" class="block text-xs text-blue-200 mb-1">Tu Experiencia</label>
          <textarea id="comentario" name="comentario" rows="3" required class="w-full bg-navy-dark border border-navy-light rounded px-3 py-2 text-white focus:outline-none focus:border-blue-400 text-sm resize-none" placeholder="Cuéntanos cómo te sentimos..."></textarea>
        </div>
        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white py-2 rounded font-medium transition-colors text-sm shadow">
          Enviar Testimonio
        </button>
      </form>
    </div>

    <script is:inline>
      // Quick check for query param to show success alert
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('testimonial') === 'submitted') {
        alert("¡Gracias! Tu testimonio ha sido enviado y está pendiente de moderación.");
        // clean url
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    </script>
  </div>
</section>
