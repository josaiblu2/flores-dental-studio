---
let published = [];

try {
  const { getStore } = await import('@netlify/blobs');
  const store = getStore({ name: 'testimonials' });
  const allTestimonials = await store.get('all', { type: 'json' }) as any[];
  if (allTestimonials) {
    published = allTestimonials.filter((t: any) => t.is_published === true);
  }
} catch (error) {
  console.error("Error reading testimonials from blobs:", error);
}

// Helper to truncate last name
const truncateName = (fullName: string) => {
  const parts = fullName.trim().split(' ');
  if (parts.length > 1) {
    const firstName = parts[0];
    const lastName = parts[parts.length - 1];
    return `${firstName} ${lastName.charAt(0)}.`;
  }
  return fullName;
};
---

<section id="testimonios" class="py-24 bg-navy-dark text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="text-blue-300 tracking-widest uppercase text-xs font-semibold">Experiencias Reales</span>
      <h2 class="font-serif text-3xl md:text-4xl mt-2">Lo que dicen nuestros pacientes</h2>
      <div class="w-16 h-1 bg-blue-300 mx-auto mt-6 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      {published.map((t) => (
        <div class="bg-navy p-8 rounded shadow-lg border-t-2 border-blue-400">
          <svg class="h-8 w-8 text-blue-300 mb-4 opacity-50" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-gray-200 font-light italic mb-6 leading-relaxed">"{t.comentario}"</p>
          <div class="flex items-center">
            <div class="h-10 w-10 bg-blue-900 rounded-full flex items-center justify-center text-blue-200 font-serif font-bold">
              {t.nombre_paciente.charAt(0)}
            </div>
            <div class="ml-4">
              <h4 class="font-medium text-white">{truncateName(t.nombre_paciente)}</h4>
              <p class="text-xs text-blue-300 font-light">Paciente Verificado</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Submission Form + In-place success */}
    <div id="testimonial-card" class="max-w-2xl mx-auto bg-navy rounded p-8 border border-navy-light text-center">
      <h3 class="font-serif text-2xl mb-2">¿Nos visitaste recientemente?</h3>
      <p class="text-gray-300 font-light text-sm mb-6">Comparte tu experiencia. Tu reseña ayuda a otros pacientes a encontrar atención odontológica ética.</p>
      
      <div class="space-y-4 text-left">
        <div>
          <label for="nombre_paciente" class="block text-xs text-blue-200 mb-1">Nombre Completo</label>
          <input type="text" id="nombre_paciente"
            class="w-full bg-navy-dark border border-navy-light rounded px-3 py-2 text-white focus:outline-none focus:border-blue-400 text-sm"
            placeholder="Ej. Juan Pérez" />
        </div>
        <div>
          <label for="comentario" class="block text-xs text-blue-200 mb-1">Tu Experiencia</label>
          <textarea id="comentario" rows="3"
            class="w-full bg-navy-dark border border-navy-light rounded px-3 py-2 text-white focus:outline-none focus:border-blue-400 text-sm resize-none"
            placeholder="Cuéntanos cómo te sentimos..."></textarea>
        </div>
        <button
          type="button"
          id="testimonial-submit-btn"
          onclick="window.__enviarTestimonio()"
          class="w-full bg-blue-600 hover:bg-blue-500 text-white py-2 rounded font-medium transition-colors text-sm shadow">
          Enviar Testimonio
        </button>
        <p id="testimonial-error" class="hidden text-red-400 text-xs mt-2"></p>
      </div>
    </div>

    {/* Hidden form for Netlify Notifications */}
    <form name="notificacion_testimonio" method="POST" data-netlify="true" hidden>
      <input type="hidden" name="form-name" value="notificacion_testimonio" />
      <input type="text" name="nombre" />
      <textarea name="comentario"></textarea>
    </form>

    <script is:inline>
    window.__enviarTestimonio = async function() {
      var nombre = (document.getElementById('nombre_paciente').value || '').trim();
      var comentario = (document.getElementById('comentario').value || '').trim();
      var errEl = document.getElementById('testimonial-error');
      var btn = document.getElementById('testimonial-submit-btn');

      if (!nombre) { errEl.textContent = 'Por favor ingresa tu nombre.'; errEl.classList.remove('hidden'); return; }
      if (!comentario) { errEl.textContent = 'Por favor escribe tu experiencia.'; errEl.classList.remove('hidden'); return; }

      errEl.classList.add('hidden');
      btn.disabled = true;
      btn.innerText = 'Enviando...';

      try {
        // 1. Save to Blobs via API
        const response = await fetch('/api/testimonials', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre_paciente: nombre, comentario: comentario })
        });

        const data = await response.json();
        if (data.success) {
          // 2. Trigger Netlify Form Notification (silent background submit)
          try {
            const formData = new URLSearchParams();
            formData.append('form-name', 'notificacion_testimonio');
            formData.append('nombre', nombre);
            formData.append('comentario', comentario);
            
            await fetch('/', {
              method: 'POST',
              headers: { "Content-Type": "application/x-www-form-urlencoded" },
              body: formData.toString()
            });
          } catch (e) { console.error("Notification trigger failed", e); }

          // 3. Final Redirect
          window.location.href = '/gracias-testimonio';
        } else {
          throw new Error('Server error');
        }
      } catch (e) {
        console.error("Error submitting testimonial:", e);
        errEl.textContent = 'Error al enviar. Intenta nuevamente.';
        errEl.classList.remove('hidden');
        btn.disabled = false;
        btn.innerText = 'Enviar Testimonio';
      }
    };
    </script>
  </div>
</section>
