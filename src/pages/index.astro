---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import EthicalPillars from '../components/EthicalPillars.astro';
import ServiceCatalog from '../components/ServiceCatalog.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';

// Placeholder for future components
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Flores Dental Studio | Odontología de Excelencia en Ecatepec" description="Clínica dental de alta gama en Las Américas, Ecatepec. Diagnóstico honesto, ética clínica y trato cálido humano.">
  <Header />
  
  <main>
    <Hero />
    <EthicalPillars />
    <ServiceCatalog />
    
    {/* Experiencias Reales (CMS Testimonials) */}
    <Testimonials />
    
    {/* FAQ block */}
    <FAQ />
    
    {/* Contact block */}
    <ContactForm />
  </main>
  
  <Footer />
</Layout>
