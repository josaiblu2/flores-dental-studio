---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mensaje Recibido | Flores Dental Studio" description="Gracias por contactar a Flores Dental Studio. Hemos recibido tu mensaje.">
  <Header />

  <!-- Fondo Azul Glaciar exigido: #F0F8FF -->
  <main class="py-24 bg-[#F0F8FF] flex-grow flex items-center justify-center min-h-[70vh]">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 w-full text-center">
      
      <div class="bg-white p-12 rounded-lg shadow-xl border-t-4 border-navy">
        <div class="mb-6 flex justify-center">
          <div class="h-20 w-20 bg-green-100 rounded-full flex items-center justify-center">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
        
        <h1 class="font-serif text-3xl text-navy mb-4">¡Envío Exitoso!</h1>
        
        <p class="text-gray-600 font-light mb-8 leading-relaxed">
          Hemos recibido tu información correctamente. Te hemos enviado un correo de confirmación y la Dra. Flores revisará tu caso a la brevedad.
        </p>

        <a href="/" class="inline-flex items-center justify-center px-8 py-3 bg-navy text-white rounded font-medium hover:bg-navy-light transition-colors shadow">
          Volver a la Página Principal
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
