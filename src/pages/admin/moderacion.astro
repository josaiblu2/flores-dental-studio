---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import fs from 'node:fs/promises';
import path from 'node:path';

export const prerender = false;

const dataPath = path.join(process.cwd(), 'src/data/testimonials.json');
let pending = [];

try {
  const rawData = await fs.readFile(dataPath, 'utf-8');
  const allTestimonials = JSON.parse(rawData);
  pending = allTestimonials.filter((t: any) => t.is_published === false);
} catch (error) {
  console.error("Error reading testimonials:", error);
}
---

<Layout title="Moderación de Testimonios | Flores Dental Studio" description="Panel de moderación webmaster">
  <Header />

  <main class="py-24 bg-gray-50 flex-grow">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 border-b border-gray-200 pb-5">
        <h1 class="text-3xl font-serif text-navy">Panel de Moderación Segura</h1>
        <p class="text-gray-500 mt-2 font-light">
          Gestión de testimonios pendientes de aprobación. Solo los elementos autorizados aparecerán en el portal público.
        </p>
      </div>

      {pending.length === 0 ? (
        <div class="bg-white p-12 text-center rounded shadow-sm border border-gray-100">
          <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h2 class="text-xl text-gray-400 font-medium">No hay testimonios pendientes</h2>
          <p class="text-gray-400 font-light mt-2 text-sm">Todos los comentarios han sido moderados.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {pending.map((t) => (
            <div class="bg-white p-6 rounded shadow-sm border border-gray-200 flex flex-col justify-between" id={`testimonio-${t.id}`}>
              <div>
                <div class="text-xs text-gray-400 mb-2">{new Date(t.fecha).toLocaleDateString('es-MX')}</div>
                <h3 class="font-medium text-navy text-lg mb-3">{t.nombre_paciente}</h3>
                <p class="text-gray-600 font-light text-sm italic border-l-2 border-blue-200 pl-3 mb-6">
                  "{t.comentario}"
                </p>
              </div>
              <div class="flex space-x-3 mt-4 border-t border-gray-100 pt-4">
                <button onclick={`moderate('${t.id}', 'approve')`} class="flex-1 bg-green-50 text-green-600 hover:bg-green-600 hover:text-white transition-colors py-2 rounded text-sm font-medium border border-green-100 focus:outline-none">
                  Aprobar
                </button>
                <button onclick={`moderate('${t.id}', 'archive')`} class="flex-1 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white transition-colors py-2 rounded text-sm font-medium border border-red-100 focus:outline-none">
                  Archivar
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </main>

  <script is:inline>
    async function moderate(id, action) {
      if (!confirm(`¿Estás seguro de que deseas ${action === 'approve'? 'aprobar' : 'archivar'} este testimonio?`)) return;
      
      try {
        const response = await fetch('/api/testimonials', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action })
        });
        
        if (response.ok) {
          const card = document.getElementById(`testimonio-${id}`);
          if (card) {
            card.style.opacity = '0';
            setTimeout(() => card.remove(), 300);
            
            // Check if any cards left
            // Standard refresh for safety
            setTimeout(() => window.location.reload(), 500);
          }
        }
      } catch (e) {
        alert('Error conectando con el servidor.');
      }
    }
  </script>
</Layout>
