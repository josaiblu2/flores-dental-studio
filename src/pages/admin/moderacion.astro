---
import Layout from '../../layouts/Layout.astro';

// Server-side only
export const prerender = false;

// --- AUTH LOGIC ---
const ADMIN_PASS = import.meta.env.ADMIN_PASSWORD || 'admin123';

// Handle Logout
if (Astro.url.searchParams.has('logout')) {
  Astro.cookies.delete('flores_admin_session', { path: '/' });
  return Astro.redirect('/admin/moderacion');
}

let isLoggedIn = Astro.cookies.get('flores_admin_session')?.value === 'active';
let loginError = false;

// Handle Login Submission
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const password = data.get('password');
    
    if (password === ADMIN_PASS) {
      Astro.cookies.set('flores_admin_session', 'active', { 
        path: '/', 
        httpOnly: true, 
        secure: true, 
        sameSite: 'strict',
        maxAge: 60 * 60 * 24 * 7 // 1 week
      });
      isLoggedIn = true;
    } else {
      loginError = true;
    }
  } catch (e) {}
}

// --- DATA LOGIC (Only if logged in) ---
let pending = [];
let approved = [];

if (isLoggedIn) {
  try {
    const { getStore } = await import('@netlify/blobs');
    const store = getStore({ name: 'testimonials' });
    const all = await store.get('all', { type: 'json' }) as any[] || [];
    pending = all.filter((t: any) => !t.is_published);
    approved = all.filter((t: any) => t.is_published);
    
    // Sort by date (newest first)
    pending.sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    approved.sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
  } catch (e) {
    console.error("Error reading testimonials from blobs in moderation:", e);
  }
}
---

<Layout title="Moderación | Flores Dental Studio" description="Panel de control privado.">
  {!isLoggedIn ? (
    /* LOGIN UI */
    <div class="min-h-screen bg-[#061021] flex items-center justify-center px-4">
      <div class="max-w-md w-full bg-[#0a1628] p-10 rounded-lg border border-blue-900/30 shadow-2xl">
        <div class="text-center mb-10">
          <div class="logo font-serif text-2xl text-white tracking-widest mb-1">FLORES</div>
          <div class="logo-sub text-[10px] text-blue-400 tracking-[0.3em] font-light">DENTAL STUDIO</div>
          <div class="w-8 h-px bg-blue-900 mx-auto mt-6"></div>
        </div>
        
        <h1 class="text-xl text-center text-white font-serif mb-8">Acceso Restringido</h1>
        
        <form method="POST" class="space-y-6">
          <div>
            <label for="password" class="block text-xs uppercase tracking-widest text-gray-500 mb-2 font-medium">Contraseña</label>
            <input 
              type="password" 
              name="password" 
              id="password" 
              required
              autofocus
              class="w-full bg-[#050b16] border border-blue-900/40 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-blue-500 transition-colors text-sm"
              placeholder="••••••••"
            />
          </div>
          
          {loginError && (
            <p class="text-red-400 text-xs text-center animate-shake">Contraseña incorrecta. Intente nuevamente.</p>
          )}
          
          <button 
            type="submit" 
            class="w-full bg-blue-600 hover:bg-blue-500 text-white font-medium py-3 rounded-sm transition-all shadow-lg active:scale-[0.98]"
          >
            Entrar al Panel
          </button>
        </form>
        
        <p class="mt-10 text-center text-[11px] text-gray-600 font-light">
          &copy; {new Date().getFullYear()} Flores Dental Studio — Área Privada
        </p>
      </div>
    </div>
  ) : (
    /* DASHBOARD UI */
    <div class="min-h-screen bg-[#08152b] text-white pt-24 pb-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {/* Header */}
      <div class="flex flex-col md:flex-row md:items-center justify-between mb-12 border-b border-blue-900/50 pb-8">
        <div>
          <h1 class="font-serif text-4xl mb-2">Panel de Moderación</h1>
          <p class="text-blue-300 font-light">Gestione las experiencias compartidas por sus pacientes.</p>
        </div>
        <div class="mt-4 md:mt-0 flex gap-4 items-center">
          <div class="bg-navy-dark px-4 py-2 rounded border border-blue-800/30 text-center">
            <span class="block text-2xl font-bold text-blue-400">{pending.length}</span>
            <span class="text-[10px] uppercase tracking-widest text-gray-400">Pendientes</span>
          </div>
          <div class="bg-navy-dark px-4 py-2 rounded border border-blue-800/30 text-center">
            <span class="block text-2xl font-bold text-gray-300">{approved.length}</span>
            <span class="text-[10px] uppercase tracking-widest text-gray-400">Publicados</span>
          </div>
          <a 
            href="?logout=true" 
            class="text-xs text-gray-500 hover:text-red-400 transition-colors uppercase tracking-widest ml-2"
          >
            Salir
          </a>
        </div>
      </div>

      {/* Pending Section */}
      <section class="mb-20">
        <h2 class="text-xl font-sans font-semibold mb-6 flex items-center">
          <span class="w-2 h-2 bg-yellow-400 rounded-full mr-3 animate-pulse"></span>
          Nuevos testimonios por aprobar
        </h2>

        {pending.length === 0 ? (
          <div class="bg-navy-dark/50 border border-dashed border-blue-900 rounded-lg p-12 text-center">
            <p class="text-gray-500 italic">No hay comentarios pendientes en este momento.</p>
          </div>
        ) : (
          <div class="grid gap-6">
            {pending.map((t) => (
              <div class="bg-navy-dark border border-blue-900/50 rounded-lg p-6 hover:border-blue-700 transition-colors shadow-xl group" id={`card-${t.id}`}>
                <div class="flex justify-between items-start mb-4">
                  <div>
                    <h3 class="text-lg font-medium text-blue-100">{t.nombre_paciente}</h3>
                    <span class="text-xs text-gray-500">{new Date(t.fecha).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                  </div>
                  <div class="flex gap-2 opacity-80 group-hover:opacity-100 transition-opacity">
                    <button 
                      onclick={`handleAction(event, '${t.id}', 'approve')`}
                      class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-1.5 rounded text-sm font-medium transition-all shadow-lg active:scale-95"
                    >
                      Aprobar
                    </button>
                    <button 
                      onclick={`handleAction(event, '${t.id}', 'archive')`}
                      class="bg-red-900/30 hover:bg-red-900/50 text-red-300 border border-red-900/50 px-4 py-1.5 rounded text-sm font-medium transition-all active:scale-95"
                    >
                      Archivar
                    </button>
                  </div>
                </div>
                <p class="text-gray-300 font-light leading-relaxed italic border-l-2 border-blue-800 pl-4 py-1">
                  "{t.comentario}"
                </p>
              </div>
            ))}
          </div>
        )}
      </section>

      {/* Published Section */}
      <section class="mb-16">
        <h2 class="text-xl font-serif mb-6 text-gray-400 uppercase tracking-widest text-sm">Testimonios ya publicados</h2>
        <div class="grid gap-4">
          {approved.map((t) => (
            <div class="bg-navy-dark/40 border border-blue-900/30 rounded-lg p-4 flex justify-between items-center group" id={`card-${t.id}`}>
              <div class="flex-1">
                <p class="text-sm text-gray-300 italic mb-1">"{t.comentario}"</p>
                <p class="text-[11px] text-blue-400 font-medium">— {t.nombre_paciente}</p>
              </div>
              <button 
                onclick={`handleAction(event, '${t.id}', 'archive')`}
                class="ml-6 text-[10px] text-gray-600 hover:text-red-400 uppercase tracking-widest transition-colors opacity-0 group-hover:opacity-100"
              >
                Eliminar
              </button>
            </div>
          ))}
        </div>
      </section>

      {/* Information Box */}
      <div class="bg-blue-900/20 border border-blue-800/50 rounded p-6 flex items-start gap-4">
        <svg class="w-6 h-6 text-blue-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <p class="text-sm text-blue-200 font-light leading-relaxed">
          <strong>CONSEJO:</strong> Ahora puedes eliminar testimonios incluso después de haberlos aprobado usando el botón pequeño a la derecha en la lista de "Publicados".
        </p>
      </div>

    </div>
  </div>

  <script is:inline>
    async function handleAction(event, id, action) {
      if (!confirm(`¿Estás seguro de que deseas ${action === 'approve' ? 'aprobar' : 'eliminar/archivar'} este testimonio?`)) return;

      const btn = event.currentTarget;
      const originalText = btn.innerText;
      btn.disabled = true;
      btn.innerText = '...';

      try {
        const res = await fetch('/api/testimonials', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, action })
        });

        const data = await res.json();
        if (data.success) {
          const card = document.getElementById(`card-${id}`);
          if (card) {
            card.style.opacity = '0';
            setTimeout(() => window.location.reload(), 300);
          } else {
            window.location.reload();
          }
        } else {
          alert('Error en el servidor.');
          btn.disabled = false;
          btn.innerText = originalText;
        }
      } catch (e) {
        console.error(e);
        alert('Error de conexión.');
        btn.disabled = false;
        btn.innerText = originalText;
      }
    }
  </script>
)}
</Layout>
